    },
    "Streaks" : {
      "comment" : "XP breakdown: streak XP",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Streaks"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Séries"
          }
        }
      }
    },
    "Streaks track consecutive days you log a travel. Each day of your streak earns a bonus of 5 × streak day in XP (capped at 50 XP/day). If you miss a day, the streak resets. Keep it going to unlock the 7-day and 30-day achievements!" : {
      "comment" : "FAQ: streaks answer",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Streaks track consecutive days you log a travel. Each day of your streak earns a bonus of 5 × streak day in XP (capped at 50 XP/day). If you miss a day, the streak resets. Keep it going to unlock the 7-day and 30-day achievements!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les séries comptabilisent les jours consécutifs où vous enregistrez un trajet. Chaque jour de série vous rapporte un bonus de 5 × jour de série en XP (plafonné à 50 XP/jour). Si vous manquez un jour, la série est réinitialisée. Continuez sur votre lancée pour débloquer les succès de 7 et 30 jours !"
          }
        }
      }
    },
    "Tap + to get started" : {
      "comment" : "Travel history: empty state hint",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap + to get started"
          }
